# Copy into Streamlit Community Cloud → App settings → Secrets (TOML).
# Do NOT commit a real secrets.toml (gitignored).

ENV = "cloud"
SOMA_DASHBOARD_FIXTURE = "0"
SOMA_CLOUD_DASHBOARD = "1"

# Supabase session pooler URI (Dashboard → Connect → Session pooler)
SOMA_DATABASE_URL = "postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# Supabase Auth (publishable anon key — RLS protects data)
SUPABASE_URL = "https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY = "eyJ..."

# Coaching chat + history queries
ANTHROPIC_API_KEY = "sk-ant-..."

# Optional: guidelines S3 (IAM user with access to guidelines/{user_id}/ only)
# SOMA_GUIDELINES_BUCKET = "your-bucket-name"
# AWS_ACCESS_KEY_ID = "..."
# AWS_SECRET_ACCESS_KEY = "..."
# AWS_DEFAULT_REGION = "us-west-2"
