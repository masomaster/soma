# Copy to .env and fill in (never commit .env)
# ENV controls delivery and AWS behavior per .cursor/rules/soma.mdc
ENV=local

# Supabase (when wiring client or REST from scripts)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # trusted automation only — never in client apps

# Anthropic (briefing / anomaly jobs)
# ANTHROPIC_API_KEY=
