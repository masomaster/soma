# Copy to .env and fill in (never commit .env)
# ENV controls delivery and AWS behavior per .cursor/rules/soma.mdc
ENV=local

# --- Phase 3 smoke: scripts/smoke_hevy.py (see docs/plans/local-dev-and-tooling.md) ---

# Hevy Pro API (same secret as Bruno HEVY_API_KEY)
# HEVY_API_KEY=

# Tenant UUID on each normalized row (matches strength_events.user_id in the schema).
# In a live Soma system this is always a real Supabase Auth user id (auth.users.id) —
# the person/tenant whose data you store (separate from Hevy's workout ids; those go
# in source_id).
#
# No Supabase yet?
#   • "live" and "raw-disk" smoke only talk to Hevy and local files — any valid UUID
#     string is fine (e.g. 00000000-0000-0000-0000-000000000001) so you can test shapes.
#   • "db-upsert" needs Supabase: create a project, apply migrations, add a user under
#     Dashboard → Authentication → Users, then set SOMA_USER_ID to that user's UID
#     (FK to auth.users).
# SOMA_USER_ID=00000000-0000-0000-0000-000000000001

# --- Phase 7 smoke: scripts/smoke_apple_health.py (JSON file → biometrics; see docs/plans/apple-health-export.md) ---
# SOMA_USER_ID=   # required for raw-disk / db-upsert (auth.users UUID)

# --- Phase 7 smoke: scripts/smoke_strava.py (OAuth access token — expires; refresh out of band) **paused** ---
# STRAVA_ACCESS_TOKEN=

# Raw JSON on disk instead of S3 (default: tmp/soma_raw under repo; tmp/ is gitignored)
# SOMA_RAW_LOCAL_DIR=tmp/soma_raw

# Postgres connection URI for db-upsert — prefer Session pooler (IPv4) from Dashboard → Connect;
# direct db.*.supabase.co is IPv6-only on most projects (see local-dev-and-tooling.md).
# SOMA_DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require

# Optional: Apple Health webhook HMAC (header X-Soma-Webhook-Secret); Lambda reads soma-apple-health-webhook secret.
# APPLE_HEALTH_WEBHOOK_SECRET=

# --- CalDAV smoke: scripts/smoke_caldav.py ---
# CALDAV_URL=https://caldav.icloud.com
# CALDAV_USERNAME=you@icloud.com
# CALDAV_PASSWORD=xxxx-xxxx-xxxx-xxxx   # app-specific password
# CALDAV_CALENDAR_NAME=Mason            # optional; exact/substring match on display name

# Supabase (REST / clients — optional for other scripts)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # trusted automation only — never in client apps

# Anthropic (briefing / anomaly jobs)
# ANTHROPIC_API_KEY=

# Optional: full URL for “Open your dashboard” in HTML briefing emails (Lambda / SES)
# BRIEFING_EMAIL_DASHBOARD_URL=https://your-app.example/dashboard

# --- Phase 9 dashboard: streamlit run dashboard/app.py ---
# SOMA_DASHBOARD_FIXTURE=0   # force live Postgres (default: live when SOMA_USER_ID + SOMA_DATABASE_URL set)
# Uses SOMA_USER_ID and SOMA_DATABASE_URL from above.
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_ANON_KEY=         # enables sign-in UI (Path A: user JWT + RLS)
# ANTHROPIC_API_KEY=         # real coaching + history-query LLM replies

# --- Phase 10 guidelines (briefing + coaching context) ---
# Local dev: markdown under SOMA_GUIDELINES_LOCAL_DIR/guidelines/{user_id}/
# SOMA_GUIDELINES_LOCAL_DIR=tmp/soma_guidelines
# AWS Lambda: S3 bucket for per-user corpus. Provisioned by the CDK stack and set
# automatically on the briefing Lambda; the name is emitted as the GuidelinesBucketName
# stack output (copy it here only for local scripts that hit the cloud bucket).
# SOMA_GUIDELINES_BUCKET=
